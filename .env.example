# Continuum Parser Environment Variables
# Copy this to .env and fill in your actual values

# PostgreSQL Database URL from Railway
# Format: postgresql://postgres:PASSWORD@HOST:PORT/railway
# Get this from: Railway Dashboard → Database → Variables → DATABASE_URL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@monorail.proxy.rlwy.net:12345/railway

# Local Embedding Service URL
# This should point to your locally running embedding service
EMBEDDER_URL=http://localhost:3000

# IMPORTANT NOTES:
# 1. DATABASE_URL MUST start with "postgresql://" NOT "https://"
# 2. EMBEDDER_URL should be http://localhost:3000 when running locally
# 3. Do NOT commit this file to git (it's in .gitignore)
